# Database
DATABASE_URL=postgresql://postgres:change-me@db:5432/finance
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Plaid credentials are now configured per-household in Settings > Integrations.
# No global Plaid env vars are needed.

# Encryption key for Plaid access tokens and credentials
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Google OAuth - create at https://console.cloud.google.com/ (OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=
# Also set in the frontend .env as NEXT_PUBLIC_GOOGLE_CLIENT_ID

# JWT secret for session cookies
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=
SECURE_COOKIES=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# LLM credentials are now configured per-household in Settings > AI Categorization.
# No global LLM env vars are needed.

# Sync schedule is now configured per-household in Settings > Sync Schedule.
# No global sync env vars are needed.

# Email (SMTP) — for partner invitation notifications
# Works with Gmail (smtp.gmail.com), SendGrid (smtp.sendgrid.net), Mailgun, etc.
# Leave SMTP_HOST empty to disable email sending (invitations still work, just no email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=FinanceApp
SMTP_USE_TLS=true
APP_URL=http://localhost:3000

# App
DEBUG=false
RUN_SCHEDULER=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
AUTH_RATE_LIMIT_PER_MINUTE=30
PLAID_RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_TRUST_PROXY=false
RATE_LIMIT_BACKEND=memory
REDIS_URL=redis://redis:6379/0
