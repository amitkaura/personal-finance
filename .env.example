# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/finance

# Plaid credentials - get from https://dashboard.plaid.com/
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Encryption key for Plaid access tokens
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# LLM Categorization (OpenAI-compatible — also works with Ollama, Azure, etc.)
# For Ollama: LLM_BASE_URL=http://localhost:11434/v1, LLM_API_KEY=ollama, LLM_MODEL=llama3
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Scheduled transaction sync (runs daily)
SYNC_ENABLED=true
SYNC_HOUR=0
SYNC_MINUTE=0
SYNC_TIMEZONE=America/Toronto

# App
DEBUG=false
